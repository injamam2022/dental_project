# CodeIgniter — try this first (works on most Apache/XAMPP)
# On Hostinger / LiteSpace, if you get 404 on all routes, try the ALT block below
# (comment this block and uncomment ALT).

<IfModule mod_rewrite.c>
	Options +FollowSymLinks -Indexes
	RewriteEngine On

	# If the app lives in a subfolder, set the base, e.g.:
	# RewriteBase /dental_project/

	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

# --- ALT: LiteSpeed / some shared hosts (uncomment, comment block above) ---
# <IfModule mod_rewrite.c>
# 	Options +FollowSymLinks -Indexes
# 	RewriteEngine On
# 	# RewriteBase /
# 	RewriteCond %{REQUEST_FILENAME} !-f
# 	RewriteCond %{REQUEST_FILENAME} !-d
# 	RewriteRule ^(.*)$ index.php?/$1 [L,QSA]
# </IfModule>

# Long cache for static file extensions (PageSpeed: cache lifetimes). Shorten if you deploy same filenames often.
<IfModule mod_headers.c>
	<FilesMatch "\.(?:css|js|mjs|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|eot)$">
		Header set Cache-Control "public, max-age=2592000"
	</FilesMatch>
</IfModule>
